#!/usr/bin/env bash
set -euo pipefail

# Make sure cargo-installed binaries are visible even if Sway session PATH is minimal
export PATH="$HOME/.cargo/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

mkdir -p "$HOME/pictures/Screenshots"
tmp="$(mktemp "$HOME/pictures/Screenshots/screenshot-XXXXXX.png")"

grim -g "$(slurp -d)" "$tmp"

# Prefer absolute path if it exists
if [[ -x "$HOME/.cargo/bin/satty" ]]; then
  exec "$HOME/.cargo/bin/satty" --filename "$tmp"
fi

# Fallback: search PATH
exec satty --filename "$tmp"
