# Ignore everything by default
*

# Allow this file
!.gitignore

# ---- Top-level configs you actually want ----
!nvim/
!sway/
!waybar/
!alacritty/
!aerc/
!autostart/
!btop/
!cava/
!gtk-3.0/
!gtk-4.0/
!ghostty/
!gtklock/
!kanshi/
!kitty/
!lazygit/
!libinput-gestures.conf
!mako/
!mimeapps.list
!neofetch/
!foot/
!ranger/
!satty/
!starship.toml
!systemd/
!wofi/
!zathura/

# ---- Keep contents of allowed dirs ----
!nvim/**
!sway/**
!waybar/**
!alacritty/**
!aerc/**
!autostart/**
!btop/**
!cava/**
!gtk-3.0/**
!gtk-4.0/**
!ghostty/**
!gtklock/**
!kanshi/**
!kitty/**
!lazygit/**
!libinput-gestures.conf
!mako/**
!mimeapps.list
!neofetch/**
!foot/**
!ranger/**
!satty/**
!starship.toml
!systemd/**
!wofi/**
!zathura/**

# ---- Never commit secrets ----
**/accounts.conf
**/accounts.imap.backup.conf
**/accounts.maildir.conf
**/accounts.maildir.active.conf
**/accounts.notmuch.conf
**/mbsyncrc
**/gmx-password
**/gmail-refresh-token
**/tuwien-refresh-token
**/*refresh-token*
**/*access-token*
**/*oauth*
**/*token
**/*token.*
**/*password
**/*password.*
**/*.secret
**/*.secrets
**/*credentials*
**/*.key
**/.env
**/.env.*

# ---- Explicit heavy / machine-specific exclusions ----
.cache/
Code/
chromium/
google-chrome/
BraveSoftware/
discord/
Slack/
spotify/
obs-studio/
JetBrains/
VirtualBox/
libreoffice/
pulse/
dconf/
xfce4/xfconf/xfce-perchannel-xml/keyboard-layout.xml
