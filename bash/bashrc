_alacritty_clone_detect_pid() {
  local pid="$$"
  local parent comm

  while [ "$pid" -gt 1 ] 2>/dev/null; do
    comm=$(ps -p "$pid" -o comm= 2>/dev/null | tr -d '[:space:]')
    if [ "$comm" = "alacritty" ]; then
      printf '%s\n' "$pid"
      return 0
    fi
    parent=$(ps -p "$pid" -o ppid= 2>/dev/null | tr -d '[:space:]')
    if [ -z "$parent" ] || [ "$parent" = "$pid" ]; then
      break
    fi
    pid="$parent"
  done

  return 1
}

_alacritty_clone_state_file() {
  local window_pid="${ALACRITTY_CLONE_WINDOW_PID:-}"
  if [ -z "$window_pid" ]; then
    window_pid=$(_alacritty_clone_detect_pid 2>/dev/null) || return 1
    ALACRITTY_CLONE_WINDOW_PID="$window_pid"
    export ALACRITTY_CLONE_WINDOW_PID
  fi
  printf '%s/alacritty-clone/%s\n' "${XDG_STATE_HOME:-$HOME/.local/state}" "$window_pid"
}

_alacritty_clone_prune_state() {
  local state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/alacritty-clone"
  local entry name

  [ -d "$state_dir" ] || return
  rm -f "$state_dir/current"

  for entry in "$state_dir"/*; do
    [ -e "$entry" ] || continue
    name=${entry##*/}
    case "$name" in
      ''|*[!0-9]*)
        continue
        ;;
    esac
    kill -0 "$name" 2>/dev/null || rm -f "$entry"
  done
}

_alacritty_clone_write_state() {
  local mode="$1"
  local user="$2"
  local host="$3"
  local cwd="$4"
  local target="${5:-}"
  local state_file state_dir

  state_file=$(_alacritty_clone_state_file) || return
  state_dir=${state_file%/*}
  mkdir -p "$state_dir" 2>/dev/null || return

  {
    printf 'mode=%q\n' "$mode"
    printf 'user=%q\n' "$user"
    printf 'host=%q\n' "$host"
    printf 'cwd=%q\n' "$cwd"
    printf 'target=%q\n' "$target"
  } > "$state_file"
}

_alacritty_clone_local_prompt() {
  [ -n "${SSH_CONNECTION:-}" ] && return
  if [ -z "${ALACRITTY_CLONE_PRUNED:-}" ]; then
    _alacritty_clone_prune_state
    ALACRITTY_CLONE_PRUNED=1
    export ALACRITTY_CLONE_PRUNED
  fi
  _alacritty_clone_write_state \
    local \
    "$(id -un 2>/dev/null || printf '%s' "${USER:-$LOGNAME}")" \
    "$(hostname -f 2>/dev/null || hostname 2>/dev/null || printf '%s' "${HOSTNAME:-localhost}")" \
    "$PWD"
}

