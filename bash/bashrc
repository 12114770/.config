_pacman_args_include() {
  local needle="$1"
  shift

  local arg
  for arg in "$@"; do
    case "$arg" in
      --)
        return 1
        ;;
      "$needle")
        return 0
        ;;
      -[!-]*)
        case "$arg" in
          *"$needle"*)
            return 0
            ;;
        esac
        ;;
    esac
  done

  return 1
}

_pacman_should_update_codex() {
  _pacman_args_include --print "$@" && return 1
  _pacman_args_include p "$@" && return 1
  _pacman_args_include --sync "$@" || _pacman_args_include S "$@" || return 1
  _pacman_args_include --sysupgrade "$@" || _pacman_args_include u "$@"
}

_pacman_rebuild_ipu7_acpi() {
  command -v dkms >/dev/null 2>&1 || return 0
  [ -d /var/lib/dkms/ipu7-drivers ] || return 0

  command sudo bash -lc '
    set -e

    version=""
    for source in /var/lib/dkms/ipu7-drivers/*/source; do
      [ -e "$source" ] || continue
      version=${source%/source}
      version=${version##*/}
      break
    done

    [ -n "$version" ] || exit 0

    needs_rebuild=0

    for build_dir in /usr/lib/modules/*/build; do
      [ -e "$build_dir" ] || continue
      kernel=${build_dir%/build}
      kernel=${kernel##*/}

      missing=0
      for module in \
        intel-ipu7.ko.zst \
        intel-ipu7-isys.ko.zst \
        intel-ipu7-psys.ko.zst \
        ipu-acpi.ko.zst \
        ipu-acpi-pdata.ko.zst \
        ipu-acpi-common.ko.zst
      do
        [ -e "/usr/lib/modules/$kernel/updates/dkms/$module" ] || missing=1
      done

      [ "$missing" -eq 1 ] || continue

      needs_rebuild=1
      printf "Rebuilding IPU7 DKMS with ACPI modules for %s\n" "$kernel"
      BUILD_INTEL_IPU_ACPI=1 dkms build --force "ipu7-drivers/$version" -k "$kernel"
      BUILD_INTEL_IPU_ACPI=1 dkms install --force "ipu7-drivers/$version" -k "$kernel"
    done

    if [ "$needs_rebuild" -eq 1 ]; then
      depmod -a
    else
      printf "IPU7 DKMS ACPI modules already match installed kernels; skipping rebuild\n"
    fi
  '
}

pacman() {
  if [ "${EUID:-$(id -u)}" -eq 0 ]; then
    command pacman "$@"
  else
    command sudo pacman "$@"
  fi
  local status=$?

  if [ "$status" -eq 0 ] && _pacman_should_update_codex "$@"; then
    _pacman_rebuild_ipu7_acpi
    printf "Updating global npm and Codex packages\n"
    command sudo npm install -g npm @openai/codex@latest
  fi

  return "$status"
}

sudo() {
  if [ "$#" -gt 0 ] && [ "$1" = "pacman" ]; then
    shift
    pacman "$@"
  else
    command sudo "$@"
  fi
}

