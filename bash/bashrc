__git_prompt_branch() {
  local branch

  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || return
  branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || git rev-parse --short HEAD 2>/dev/null) || return
  [ -n "$branch" ] || return

  printf '%s' "$branch"
}

__set_git_ps1() {
  local branch branch_segment

  if branch=$(__git_prompt_branch); then
    if [ "$__bashrc_color_prompt" = yes ]; then
      branch_segment="\[\033[01;31m\](${branch})\[\033[00m\]"
    else
      branch_segment="(${branch})"
    fi
  else
    branch_segment=
  fi

  if [ "$__bashrc_color_prompt" = yes ]; then
    PS1='${debian_chroot:+($debian_chroot)}\[\033[01;32m\]\u@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]'"$branch_segment"'\$ '
  else
    PS1='${debian_chroot:+($debian_chroot)}\u@\h:\w'"$branch_segment"'\$ '
  fi

  case "$TERM" in
  xterm* | rxvt*)
    PS1="\[\e]0;${debian_chroot:+($debian_chroot)}\u@\h: \w\a\]$PS1"
    ;;
  esac
}

__set_git_ps1
case ";${PROMPT_COMMAND:-};" in
  *";__set_git_ps1;"*) ;;
  ";;")
    PROMPT_COMMAND="__set_git_ps1"
