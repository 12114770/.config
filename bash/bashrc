esac

ssh() {
  local host_seen=0
  local needs_value=0
  local arg target=""
  local window_pid state_file port listener_pid remote_script remote_cmd

  for arg in "$@"; do
    if [ "$host_seen" -eq 1 ]; then
      command ssh "$@"
      return
    fi

    if [ "$needs_value" -eq 1 ]; then
      needs_value=0
      continue
    fi

    case "$arg" in
      --)
        host_seen=1
        ;;
      -[1246AaCfGgKkMNnqsTtVvXxYy]*)
        case "$arg" in
          *N*|*T*)
            command ssh "$@"
            return
            ;;
        esac
        ;;
      -[BbcDEeFIiJLlmOopQRSWw])
        needs_value=1
        ;;
      -[BbcDEeFIiJLlmOopQRSWw]?*)
        ;;
      -*)
        command ssh "$@"
        return
        ;;
      *)
        target="$arg"
        host_seen=1
        ;;
    esac
  done

  if [ "$host_seen" -eq 0 ]; then
    command ssh "$@"
    return
  fi

  window_pid=${ALACRITTY_CLONE_WINDOW_PID:-}
  if [ -z "$window_pid" ]; then
    window_pid=$(_alacritty_clone_detect_pid 2>/dev/null) || {
      command ssh "$@"
      return
    }
    ALACRITTY_CLONE_WINDOW_PID="$window_pid"
    export ALACRITTY_CLONE_WINDOW_PID
  fi

  state_file=$(_alacritty_clone_state_file) || {
    command ssh "$@"
    return
  }

  port=$(python3 - <<'PY'
import socket

sock = socket.socket()
sock.bind(('127.0.0.1', 0))
print(sock.getsockname()[1])
sock.close()
PY
)

  listener_pid=$(python3 - <<'PY' "$HOME/.local/bin/alacritty-clone-listener" "$port" "$state_file"
import subprocess
import sys

proc = subprocess.Popen(
    [sys.argv[1], '--port', sys.argv[2], '--state-file', sys.argv[3]],
    stdout=subprocess.DEVNULL,
    stderr=subprocess.DEVNULL,
    start_new_session=True,
)
print(proc.pid)
PY
)

  remote_script=$(cat <<EOF
_alacritty_clone_remote_prompt() {
  local payload host user
  host=$(hostname -f 2>/dev/null || hostname 2>/dev/null || printf '%s' "${HOSTNAME:-remote}")
  user=$(id -un 2>/dev/null || printf '%s' "${USER:-$LOGNAME}")
  payload=$(printf '%s\037%s\037%s\037%s\037%s' ssh "$user" "$host" "$PWD" "${ALACRITTY_CLONE_TARGET:-}" | base64 | tr -d '\n')
  exec 9<>/dev/tcp/127.0.0.1/${ALACRITTY_CLONE_PORT} || return
  printf '%s\n' "$payload" >&9
  exec 9>&-
  exec 9<&-
}
export ALACRITTY_CLONE_PORT=$port
export ALACRITTY_CLONE_TARGET=$(printf '%q' "$target")
export -f _alacritty_clone_remote_prompt
PROMPT_COMMAND=_alacritty_clone_remote_prompt
export PROMPT_COMMAND
exec bash -i
EOF
)
  remote_cmd=$(printf 'bash -lc %q' "$remote_script")

  cleanup() {
    kill "$listener_pid" 2>/dev/null || true
  }
  trap cleanup RETURN

  command ssh -R "$port:127.0.0.1:$port" -t "$@" "$remote_cmd"
}

